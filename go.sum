TASK 4

sudo vi /usr/local/bin/build-pipeline.sh

#!/bin/bash
cd /tmp
rm -rf /tmp/payment
git clone https://github.com/dvalyayevkbtu/payment.git
cd payment
podman build -t payment-service:latest .
logger -t payment-pipeline "Audit: Container image built successfully"
podman run -d --name payment-test --memory 256m --memory-swap 256m --cpus 0.5 -p 8080:8080 payment-service:latest
logger -t payment-pipeline "Audit: Container started"
sleep 3
if curl -s http://localhost:8080 > /dev/null; then
    logger -t payment-pipeline "Audit: Service check PASSED"
else
    logger -t payment-pipeline "Audit: Service check FAILED"
fi
podman stop payment-test
podman rm payment-test
logger -t payment-pipeline "Audit: Container cleaned up and deleted"
cd /tmp
rm -rf /tmp/payment
logger -t payment-pipeline "Audit: Local Git repository purged"

sudo chmod 750 /usr/local/bin/build-pipeline.sh
sudo chown root:operations /usr/local/bin/build-pipeline.sh
sudo cp /usr/local/bin/build-pipeline.sh /home/kbtu/build-pipeline.sh
sudo vi /etc/audit/rules.d/payment-audit.rules

-w /usr/local/bin/build-pipeline.sh -p wa -k payment-pipeline-tamper

sudo cp /etc/audit/rules.d/payment-audit.rules /home/kbtu/payment-audit.rules
sudo augenrules --load

TASK 5

sudo vi /etc/nftables.conf
Plaintext
#!/usr/sbin/nft -f
flush ruleset
table inet filter {
  chain input {
    type filter hook input priority 0;
    ct state established,related accept
    iif "lo" accept
    tcp dport { 22, 4200 } accept
    drop
  }
  chain forward { type filter hook forward priority 0; }
  chain output { type filter hook output priority 0; }
}

sudo cp /etc/nftables.conf /home/kbtu/nftables.conf
sudo nft -f /etc/nftables.conf
sudo systemctl enable --now nftables
